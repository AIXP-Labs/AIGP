{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainp.dev/schemas/ainp-generation-v1.0.0.schema.json",
  "title": "AINP generation plan (ainp.v1.0.0.generation)",
  "description": "A machine-readable, governable generation plan: what to create, under which constraints, which content files/points to produce, and what counts as done. A VALID plan proves structure and declarations only — never artifact safety, originality, rights, factuality or compliance. Cross-field rules (G1-G16) are enforced by tools/ainp_validate.py; this Draft 2020-12 schema covers shape, closed enums and required fields. The stdlib release wrapper validates only the bundled-schema keywords this repository uses; tests use jsonschema for full Draft 2020-12 validation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "generation"],
  "properties": {
    "schema": { "const": "ainp.v1.0.0.generation" },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "title", "summary", "status", "artifact_type",
                   "brief", "acceptance_criteria",
                   "governance", "risk_profile", "disclosure_policy"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(-((0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(\\.(0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(\\+([0-9A-Za-z-]+)(\\.([0-9A-Za-z-]+))*)?$" },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "status": { "enum": ["draft", "under_review", "approved", "active", "superseded", "retired"] },
        "source": { "enum": ["human", "agent", "hybrid"] },
        "artifact_type": { "type": "string", "minLength": 1,
          "description": "Open string; suggested enum (document/code/image/audio/video/dataset/design/landing_page/campaign/3d/mixed) enforced as WARN by the validator (G3), not by this schema." },
        "artifact_subtype": { "type": "string" },
        "brief": {
          "type": "object",
          "additionalProperties": false,
          "required": ["goal"],
          "properties": {
            "goal": { "type": "string", "minLength": 1 },
            "tone": { "type": "string" },
            "requirements": { "type": "array", "items": { "type": "string" } }
          }
        },
        "audience": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "primary": { "type": "string" }, "secondary": { "type": "string" } }
        },
        "structure": {
          "type": "array",
          "items": { "$ref": "#/$defs/structure_node" }
        },
        "content_architecture": {
          "type": "object",
          "additionalProperties": false,
          "description": "Optional for standalone plans and required by complete <name>_ainp project packages. Declarative content project blueprint: generated-content root, directories, files and per-file points. It is planning structure, not an execution graph.",
          "required": ["root", "files"],
          "properties": {
            "root": { "type": "string", "minLength": 1,
              "description": "Generated content root directory, relative to the active project/package root." },
            "directories": {
              "type": "array",
              "items": { "$ref": "#/$defs/content_directory" }
            },
            "files": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/content_file" }
            }
          }
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/input" }
        },
        "rights_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default_status": { "$ref": "#/$defs/rights_status" },
            "reuse_requires": { "type": "array", "items": { "$ref": "#/$defs/rights_status" } }
          }
        },
        "risk_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["risk_level", "risk_tags", "deployment_scope"],
          "properties": {
            "risk_level": { "$ref": "#/$defs/risk_level" },
            "risk_tags": { "type": "array", "items": { "type": "string" },
              "description": "Closed value domain = high_risk_types.v1.0.0.json risk_tags[].id (enforced by validator G6, not by this schema)." },
            "deployment_scope": { "enum": ["internal_draft", "limited", "public", "mass_public"] },
            "intended_audience": { "type": "string",
              "description": "Advisory free text in v1.0.0; NOT part of gate judgment. Minor/vulnerable-audience risk goes through risk_tags (e.g. minor_related)." },
            "rationale": { "type": "string" },
            "affected_subjects": { "type": "array", "items": { "type": "string" },
              "description": "Optional extension field (v1.0.0: allowed, not used by gates)." },
            "vulnerable_groups": { "type": ["boolean", "array"], "items": { "type": "string" },
              "description": "Optional extension field (v1.0.0: allowed, not used by gates)." }
          }
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/criterion" }
        },
        "disclosure_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ai_generated_disclosure_required"],
          "properties": {
            "ai_generated_disclosure_required": { "type": "boolean" },
            "human_visible_label_required": { "type": "boolean" },
            "machine_readable_metadata_required": { "type": "boolean" },
            "generator_metadata_required": { "type": "boolean",
              "description": "If true, the report must record generator identity metadata (provider, system, content_id, generated_at). This records provenance evidence; it is not provider trust proof." },
            "content_credential_required": { "type": "boolean",
              "description": "If true, the report must record a content credential as externally verified (R7). Local AINP tools do not validate credential cryptography, issuer policy, or trust lists." },
            "watermark_required": { "type": "boolean",
              "description": "If true, the report must record watermark evidence. Local tools record presence/scheme/evidence only; they do not verify watermark robustness or detectability." },
            "removal_prohibited": { "type": "boolean" }
          }
        },
        "bindings": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "aiip_binding": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "protocol": { "type": "string" }, "intent": { "type": "string" } }
            },
            "aijp_binding": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "protocol": { "type": "string" },
                "generate_worktree": { "type": "boolean" },
                "target": { "type": "string" }
              }
            },
            "execution_binding": {
              "type": "object",
              "additionalProperties": false,
              "required": ["protocol"],
              "properties": {
                "protocol": { "enum": ["AISOP", "AISP", "AIJP", "external", "none"] },
                "target": { "type": "string" }
              }
            },
            "aikp_binding": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "protocol": { "type": "string" }, "focus": { "type": "string" } }
            }
          }
        },
        "governance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "approval_required"],
          "properties": {
            "status": { "enum": ["draft", "under_review", "approved", "active", "superseded", "retired"] },
            "risk_level": { "$ref": "#/$defs/risk_level",
              "description": "DERIVED family-compatibility field; must equal risk_profile.risk_level (G13). risk_profile is the single source of truth." },
            "review_required": { "type": "boolean" },
            "approval_required": { "type": "boolean" },
            "created_by": { "type": "string" }
          }
        },
        "permission": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "can_generate_artifact": { "type": "boolean" } }
        }
      }
    }
  },
  "$defs": {
    "risk_level": { "enum": ["low", "medium", "high", "critical"] },
    "rights_status": { "enum": ["owned", "licensed", "public_domain", "open_license",
                                "public_reference", "user_provided", "consent_required",
                                "consent_recorded", "unknown", "external_verify_required"] },
    "structure_node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "kind": { "type": "string",
          "description": "Open string; suggested enum (section/subsection/component/module/scene/asset) enforced as WARN by the validator." },
        "children": { "type": "array", "items": { "$ref": "#/$defs/structure_node" } }
      }
    },
    "content_directory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "purpose"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 }
      }
    },
    "content_file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "type", "required", "summary", "points"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "mime": { "type": "string" },
        "role": { "type": "string" },
        "required": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 },
        "points": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content_point" }
        }
      }
    },
    "content_point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "order", "title", "requirements"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "order": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1 },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "acceptance_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "source", "rights", "provenance"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "type": "string" },
            "uri": { "type": "string" }
          }
        },
        "rights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "$ref": "#/$defs/rights_status" },
            "license": { "type": ["string", "null"] },
            "holder": { "type": ["string", "null"] },
            "evidence_ref": { "type": ["string", "null"] }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "enum": ["unverified", "retrieved", "external_verify_required", "externally_verified"],
              "description": "Declared or evidence-referenced provenance state. This does not prove source authenticity or a complete lineage graph." },
            "retrieved_at": { "type": ["string", "null"] },
            "sha256": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$",
              "description": "Integrity recomputation anchor only; not a trust credential." },
            "verified_by": { "type": ["string", "null"] }
          }
        },
        "privacy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "contains_personal_data": { "type": "boolean" },
            "data_subject_category": { "type": "string" },
            "minimization_required": { "type": "boolean" },
            "retention_policy": { "type": "string" }
          }
        },
        "consent": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "required": { "type": "boolean" },
            "status": { "enum": ["not_required", "pending", "recorded", "verified", "expired", "revoked"] },
            "subject_ref": { "type": "string" },
            "evidence_ref": { "type": "string" },
            "scope": { "enum": ["single_generation", "project", "time_bounded"] },
            "expires_at": { "type": "string" },
            "verified_by": { "type": "string" }
          }
        }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "description"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["hard", "soft", "safety", "ip", "approval", "disclosure", "privacy"] },
        "category": { "type": "string" },
        "scope": { "type": "string" },
        "severity": { "enum": ["fail", "warn", "info"] },
        "condition": { "type": "string",
          "description": "Declarative text in v1.0.0: validators check existence only, never evaluate. Machine-evaluable condition_id registry is deferred to a future version." },
        "description": { "type": "string" },
        "enforced_by": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stage", "mechanism", "assurance"],
            "properties": {
              "stage": { "enum": ["plan_validation", "generation_runtime", "report_check",
                                  "distribution_gate", "external_review"] },
              "mechanism": { "type": "string", "pattern": "^(validator|report|runtime|external):.+$" },
              "assurance": { "enum": ["static", "runtime", "evidence_recorded", "external_required",
                                      "externally_verified", "attested", "unverifiable"] },
              "limitations": { "type": "string" }
            }
          }
        }
      }
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "severity", "verification"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "severity": { "enum": ["fail", "warn", "info"] },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method"],
          "properties": {
            "method": { "enum": ["static", "external", "human"] },
            "check_id": {
              "type": "string",
              "description": "Closed value domain for static checks = structure.sections_nonempty, inputs.rights_declared, length.within_bounds, disclosure.policy_declared. Enforced by validator G5, not by this schema."
            },
            "tool": { "type": "string" },
            "spec": { "type": "string" }
          }
        }
      }
    }
  }
}
