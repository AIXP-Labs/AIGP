{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ainp.dev/schemas/high_risk_types-v1.0.0.schema.json",
  "title": "AINP high-risk types (ainp.v1.0.0.high_risk_types)",
  "description": "Versioned single source of truth for high-risk generation carrier forms and declared risk-tag trigger bits. Shape-valid data is still not external trust proof; it only keeps the gate table machine-usable.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "description", "artifact_types", "risk_tags"],
  "properties": {
    "schema": { "const": "ainp.v1.0.0.high_risk_types" },
    "description": { "type": "string", "minLength": 1 },
    "artifact_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "risk_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "approval_required", "consent_required", "disclosure_required"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "approval_required": { "type": "boolean" },
          "consent_required": { "type": "boolean" },
          "disclosure_required": { "type": "boolean" }
        }
      }
    }
  }
}
